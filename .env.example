# ── Local development secrets ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Path to the jSymbolic2.jar on your local machine.
# Default (if not set): <repo>/jSymbolic/jSymbolic2.jar
jSymbolic2_path = "/path/to/jSymbolic2.jar"

# W&B API key for logging experiments locally.
# Get it from https://wandb.ai/authorize
wandb_api_key = "your_wandb_api_key"

# ── Google Colab secrets (set these in Colab's 🔑 Secrets sidebar, NOT here) ──
# These are listed here for documentation only.
#
# gdrive_proj_path
#   Path to the project folder inside your Google Drive, as seen from Colab.
#   Expected layout inside this folder:
#     data/raw/
#     data/interim/
#     data/processed/
#     data/final/
#     data/ontology/
#     jSymbolic/jSymbolic2.jar
#   Default if not set: /content/drive/MyDrive/DL-KG-project
#   Example value:      /content/drive/MyDrive/DL-KG-project
#
# WANDB_API_KEY
#   Your W&B API key (same value as wandb_api_key above).
#   Used by wandb.login() inside Colab.
