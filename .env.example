# ── Local development secrets ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Path to the jSymbolic2.jar on your local machine.
# Default (if not set): <repo>/jSymbolic/jSymbolic2.jar
jSymbolic2_path = "/path/to/jSymbolic2.jar"

# W&B API key for logging experiments locally.
# Get it from https://wandb.ai/authorize
WANDB_API_KEY = "your_wandb_api_key"

# ── Cross-environment secrets (Colab Secrets 🔑 OR this .env) ─────────────────
# The notebook bootstrap cell resolves these in this priority order:
#   1) Colab Secret (🔑 sidebar)      ← preferred on plain Colab
#   2) os.getenv() — i.e. this .env
#   3) hard-coded fallback default
#
# IMPORTANT for VS Code → Colab users
# -----------------------------------
# The kernel runs on Google's servers, NOT on your laptop, so a .env on
# your local disk is invisible.  Place this file inside your mounted
# Google Drive instead.  The bootstrap probes (in order):
#
#   a) Colab Secret  dotenv_path  (absolute path to .env in Drive)
#   b) /content/drive/MyDrive/.env
#   c) <gdrive_proj_path>/.env
#   d) <cloned_repo>/.env
#
# Recommended Colab-via-VSCode setup:
#   - one Colab Secret  gdrive_proj_path  → your Drive project folder
#   - this .env file inside that folder, with everything else.

# gdrive_proj_path
#   Absolute path to your project folder inside Google Drive, as seen from
#   the Colab runtime (i.e. it must start with /content/drive/MyDrive/...).
#   Expected layout inside this folder:
#     data/raw/
#     data/interim/
#     data/processed/
#     data/final/
#     data/ontology/
#     jSymbolic/jSymbolic2.jar
#   Default if not set: /content/drive/MyDrive/DL-KG-project
#   Examples:
#     gdrive_proj_path = "/content/drive/MyDrive/DL-KG-project"
#     gdrive_proj_path = "/content/drive/MyDrive/MsC_DtSc/sem_2/KG_DL_Project"
gdrive_proj_path = "/content/drive/MyDrive/DL-KG-project"

# repo_branch
#   Git branch the Colab bootstrap cell will clone / checkout / pull from
#   https://github.com/aarthip97/DL-KG-project.git.
#   Default if not set: "main".
#   Set this to a feature branch while it is under active development:
#     repo_branch = "graph_contruction"
repo_branch = "main"
