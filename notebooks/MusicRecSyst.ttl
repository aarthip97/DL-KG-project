@prefix : <http://purl.org/ontology/mrc/> .
@prefix ao: <http://purl.org/ontology/ao/core#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix mo: <http://purl.org/ontology/mo/> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bio: <http://purl.org/vocab/bio/0.1/> .
@prefix mrc: <http://purl.org/ontology/mrc/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcam: <http://purl.org/dc/dcam/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix frbr: <http://purl.org/vocab/frbr/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix wd: <http://www.wikidata.org/entity/> .
@prefix wdt: <http://www.wikidata.org/prop/direct/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix event: <http://purl.org/NET/c4dm/event.owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dcmitype: <http://purl.org/dc/dcmitype/> .
@base <http://purl.org/ontology/mrc/> .

<http://purl.org/ontology/mrc/> rdf:type owl:Ontology ;
                                 dc:created "2026/04/24 12:00:00" ;
                                 dc:date "2026/04/24 12:00:00" ;
                                 dc:description """Extends the Music Ontology (mo:) with concepts and properties tailored for
        music recommendation systems. Provides classes for MSD/MusicBrainz track and
        artist identification, jSymbolic MIDI feature extraction (7 categories, 246 features),
        listener modelling, and artist-level genre association."""@en ;
                                 dc:rights "This ontology is distributed under a Creative Commons Attribution 4.0 International License."@en ;
                                 dc:title "Music Recommendation System Ontology (MRC)"@en ;
                                 dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
                                 vann:preferredNamespacePrefix "mrc" ;
                                 vann:preferredNamespaceUri "http://purl.org/ontology/mrc/" ;
                                 rdfs:comment """The MRC ontology builds on the Music Ontology specification, which provides
        core concepts for describing music (artists, albums, tracks) on the Semantic Web.
        MRC adds support for audio feature extraction (jSymbolic), Million Song Dataset
        identifiers, MusicBrainz alignment, and recommendation-oriented properties."""@en ;
                                 rdfs:label "Music Recommendation System Ontology"@en ;
                                 owl:versionInfo "1.0.0"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/coverage
dc:coverage rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/created
dc:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/date
dc:date rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/identifier
dc:identifier rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/language
dc:language rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/publisher
dc:publisher rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/relation
dc:relation rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/rights
dc:rights rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/source
dc:source rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/subject
dc:subject rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/type
dc:type rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/coverage
dcterms:coverage rdf:type owl:AnnotationProperty ;
                 dcterms:description "Spatial topic and spatial applicability may be a named place or a location specified by its geographic coordinates. Temporal topic may be a named period, date, or date range. A jurisdiction may be a named administrative entity or a geographic place to which the resource applies. Recommended practice is to use a controlled vocabulary such as the Getty Thesaurus of Geographic Names [[TGN](https://www.getty.edu/research/tools/vocabulary/tgn/index.html)]. Where appropriate, named places or time periods may be used in preference to numeric identifiers such as sets of coordinates or date ranges.  Because coverage is so broadly defined, it is preferable to use the more specific subproperties Temporal Coverage and Spatial Coverage."@en ;
                 rdfs:comment "The spatial or temporal topic of the resource, spatial applicability of the resource, or jurisdiction under which the resource is relevant."@en ;
                 rdfs:label "Coverage"@en ;
                 rdfs:subPropertyOf dc:coverage .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty ;
                    dcterms:description "Description may include but is not limited to: an abstract, a table of contents, a graphical representation, or a free-text account of the resource."@en ;
                    rdfs:comment "An account of the resource."@en ;
                    rdfs:label "Description"@en ;
                    rdfs:subPropertyOf dc:description .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/relation
dcterms:relation rdf:type owl:AnnotationProperty ;
                 dcterms:description "Recommended practice is to identify the related resource by means of a URI.  If this is not possible or feasible, a string conforming to a formal identification system may be provided."@en ;
                 rdfs:comment "A related resource."@en ;
                 rdfs:label "Relation"@en ;
                 rdfs:subPropertyOf dc:relation .


###  http://purl.org/dc/terms/rights
dcterms:rights rdf:type owl:AnnotationProperty ;
               dcterms:description "Typically, rights information includes a statement about various property rights associated with the resource, including intellectual property rights.  Recommended practice is to refer to a rights statement with a URI.  If this is not possible or feasible, a literal value (name, label, or short text) may be provided."@en ;
               rdfs:comment "Information about rights held in and over the resource."@en ;
               rdfs:label "Rights"@en ;
               rdfs:subPropertyOf dc:rights .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty ;
              rdfs:range rdfs:Literal .


###  http://purl.org/ontology/mo/level
mo:level rdf:type owl:AnnotationProperty ;
         rdfs:comment """
        This annotation property associates to a particular Music Ontology term the corresponding
        expressiveness level. These levels can be:

            - 1: Only editorial/Musicbrainz type information
            - 2: Workflow information
            - 3: Even decomposition
        
        This property is mainly used for specification generation.
    """ ;
         rdfs:isDefinedBy mo: ;
         rdfs:label "level" .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2003/06/sw-vocab-status/ns#term_status
vs:term_status rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/name
foaf:name rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#gYear
xsd:gYear rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://purl.org/NET/c4dm/event.owl#agent
event:agent rdf:type owl:ObjectProperty .


###  http://purl.org/NET/c4dm/event.owl#factor
event:factor rdf:type owl:ObjectProperty .


###  http://purl.org/NET/c4dm/event.owl#isAgentIn
event:isAgentIn rdf:type owl:ObjectProperty .


###  http://purl.org/NET/c4dm/event.owl#isFactorOf
event:isFactorOf rdf:type owl:ObjectProperty .


###  http://purl.org/NET/c4dm/event.owl#product
event:product rdf:type owl:ObjectProperty .



###  http://purl.org/ontology/mo/encodes
mo:encodes rdf:type owl:ObjectProperty ;
           rdfs:domain mrc:Track ;
           rdfs:range mo:MusicalExpression ;
           mo:level "1" ;
           rdfs:comment """
        Relates a MusicalItem (a track on a particular CD, an audio file, a stream somewhere) to the signal it encodes.

        This is usually a lower-resolution version of the master signal (issued from a Recording event).
    """ ;
           rdfs:isDefinedBy mo: ;
           rdfs:label "encodes" ;
           vs:term_status "unstable" .


###  http://purl.org/ontology/mo/instrument
mo:instrument rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf event:factor ;
              rdfs:domain mo:Performance ;
              rdfs:range mo:Instrument ;
              mo:level "2" ;
              rdfs:comment "Relates a performance to a musical instrument involved" ;
              rdfs:isDefinedBy mo: ;
              vs:term_status "stable" .


###  http://purl.org/ontology/mo/item
mo:item rdf:type owl:ObjectProperty ;
        mo:level "1" ;
        rdfs:comment """
                Relates a musical manifestation to a musical item (this album, and my particular cd) holding the
                entire manifestation, and not just a part of it.
        """ ;
        rdfs:isDefinedBy mo: ;
        vs:term_status "testing" .


###  http://purl.org/ontology/mo/key
mo:key rdf:type owl:ObjectProperty ;
       mo:level "2" ;
       rdfs:comment """
        Indicated the key used by the musicians during a performance, or the key of a MusicalWork.
        Any of 24 major or minor diatonic scales that provide the tonal framework for a piece of music.""" ;
       rdfs:isDefinedBy mo: ;
       rdfs:label "key" ;
       vs:term_status "stable" .


###  http://purl.org/ontology/mo/listened
mo:listened rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf event:isAgentIn ,
                               bio:event ;
            owl:inverseOf mo:listener ;
            rdfs:domain foaf:Agent ;
            rdfs:range mo:Performance ;
            mo:level "2" ;
            rdfs:comment "Relates agents to the performances they were listening in" ;
            rdfs:isDefinedBy mo: ;
            rdfs:label "listened" ;
            vs:term_status "unstable" .


###  http://purl.org/ontology/mo/listener
mo:listener rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf event:agent ;
            rdfs:domain mo:Performance ;
            rdfs:range foaf:Agent ;
            mo:level "2" ;
            rdfs:comment "Relates a performance to the listener involved" ;
            rdfs:isDefinedBy mo: ;
            vs:term_status "stable" .


###  http://purl.org/ontology/mo/musicbrainz
mo:musicbrainz rdf:type owl:ObjectProperty ;
               mo:level "1" ;
               rdfs:comment """
        Linking an agent, a track or a record to its corresponding Musicbrainz page.
        """ ;
               rdfs:isDefinedBy mo: ;
               rdfs:label "musicbrainz" ;
               vs:term_status "stable" .

               

###  http://purl.org/ontology/mo/performed
mo:performed rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf event:isAgentIn ,
                                bio:event ;
             owl:inverseOf mo:performer ;
             rdfs:domain foaf:Agent ;
             rdfs:range mo:Performance ;
             mo:level "2" ;
             rdfs:comment "Relates agents to the performances they were performing in" ;
             rdfs:isDefinedBy mo: ;
             rdfs:label "performed" ;
             vs:term_status "unstable" .

###  http://purl.org/ontology/mo/performer
mo:performer rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf event:agent ;
             rdfs:domain mo:Performance ;
             rdfs:range foaf:Agent ;
             mo:level "2" ;
             rdfs:comment "Relates a performance to the performers involved" ;
             rdfs:isDefinedBy mo: ;
             vs:term_status "stable" .

###  http://purl.org/ontology/mrc/hasChordFeature
mrc:hasChordFeature rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf mrc:hasMusicFeature ;
                    rdfs:domain mrc:MSDTrack ;
                    rdfs:range mrc:ChordVerticalIntervalFeature ;
                    rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                    rdfs:label "has chord and vertical interval feature"@en .


###  http://purl.org/ontology/mrc/hasDynamicsFeature
mrc:hasDynamicsFeature rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf mrc:hasMusicFeature ;
                       rdfs:domain mrc:MSDTrack ;
                       rdfs:range mrc:DynamicsFeature ;
                       rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                       rdfs:label "has dynamics feature"@en .


###  http://purl.org/ontology/mrc/hasGenre
mrc:hasGenre rdf:type owl:ObjectProperty ;
             rdfs:domain mrc:MSDMusicArtist ;
             rdfs:range mrc:Genre ;
             rdfs:comment """Associates a genre with an artist. Genre is attached at the artist level
because that is the granularity available in the MSD/MusicBrainz data."""@en ;
             rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
             rdfs:label "has genre"@en .


###  http://purl.org/ontology/mrc/hasInstrumentationFeature
mrc:hasInstrumentationFeature rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf mrc:hasMusicFeature ;
                              rdfs:domain mrc:MSDTrack ;
                              rdfs:range mrc:InstrumentationFeature ;
                              rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                              rdfs:label "has instrumentation feature"@en .


###  http://purl.org/ontology/mrc/hasMelodicFeature
mrc:hasMelodicFeature rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf mrc:hasMusicFeature ;
                      rdfs:domain mrc:MSDTrack ;
                      rdfs:range mrc:MelodicIntervalFeature ;
                      rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                      rdfs:label "has melodic interval feature"@en .


###  http://purl.org/ontology/mrc/hasMusicFeature
mrc:hasMusicFeature rdf:type owl:ObjectProperty ;
                    rdfs:domain mrc:Track ;
                    rdfs:range mrc:MusicFeature ;
                    rdfs:comment "Links a track to a bundle of jSymbolic-extracted music features."@en ;
                    rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                    rdfs:label "has music feature"@en .


###  http://purl.org/ontology/mrc/hasPitchFeature
mrc:hasPitchFeature rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf mrc:hasMusicFeature ;
                    rdfs:domain mrc:MSDTrack ;
                    rdfs:range mrc:PitchStatisticsFeature ;
                    rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                    rdfs:label "has pitch statistics feature"@en .


###  http://purl.org/ontology/mrc/hasRhythmFeature
mrc:hasRhythmFeature rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf mrc:hasMusicFeature ;
                     rdfs:domain mrc:MSDTrack ;
                     rdfs:range mrc:RhythmFeature ;
                     rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                     rdfs:label "has rhythm feature"@en .


###  http://purl.org/ontology/mrc/hasTextureFeature
mrc:hasTextureFeature rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf mrc:hasMusicFeature ;
                      rdfs:domain mrc:MSDTrack ;
                      rdfs:range mrc:TextureFeature ;
                      rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                      rdfs:label "has texture feature"@en .


###  http://purl.org/ontology/mrc/hasTrack
mrc:hasTrack rdf:type owl:ObjectProperty ;
             rdfs:domain mo:Performance ;
             rdfs:range mrc:Track ;
             rdfs:comment """Links a Performance to the MRC Track that results from it.
Uses mrc:Track (not mo:Track) as the range, since mo:Track represents a MusicalItem
in the FRBR sense (a manifestation-item), while mrc:Track represents a concrete musical track as encountered in datasets such as the MSD.
Domain: mo:Performance  —  Range: mrc:Track (typically mrc:MSDTrack)."""@en ;
             rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
             rdfs:label "has track"@en .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf dc:title .


###  http://purl.org/ontology/mo/duration
mo:duration rdf:type owl:DatatypeProperty ;
            rdfs:range xsd:float ;
            mo:level "1" ;
            rdfs:comment "The duration of a track or a signal in ms" ;
            rdfs:isDefinedBy mo: ;
            vs:term_status "testing" .


###  http://purl.org/ontology/mo/musicbrainz_guid
mo:musicbrainz_guid rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf mo:uuid ;
                    mo:level "1" ;
                    rdfs:comment "Links an object to the corresponding Musicbrainz identifier" ;
                    rdfs:isDefinedBy mo: ;
                    rdfs:label "Musicbrainz GUID" ;
                    vs:term_status "testing" .


###  http://purl.org/ontology/mo/tempo
mo:tempo rdf:type owl:DatatypeProperty ;
         rdfs:range xsd:string ;
         mo:level "2" ;
         rdfs:comment """
        Rate of speed or pace of music. Tempo markings are traditionally given in Italian; 
        common markings include: grave (solemn; very, very slow); largo (broad; very slow); 
        adagio (quite slow); andante (a walking pace); moderato (moderate); allegro (fast; cheerful); 
        vivace (lively); presto (very fast); accelerando (getting faster); ritardando (getting slower); 
        and a tempo (in time; returning to the original pace).
    """ ;
         rdfs:isDefinedBy mo: ;
         rdfs:label "tempo" ;
         vs:term_status "stable" .


###  http://purl.org/ontology/mo/uuid
mo:uuid rdf:type owl:DatatypeProperty ;
        rdfs:domain owl:Thing ;
        mo:level "1" ;
        rdfs:comment """
            Links an object to an universally unique identifier for it.
    """ ;
        rdfs:label "universally unique identifier" ;
        vs:term_status "testing" .


###  http://purl.org/ontology/mrc/acousticGuitarPrevalence
mrc:acousticGuitarPrevalence rdf:type owl:DatatypeProperty ;
                             rdfs:subPropertyOf mrc:instrumentationData ;
                             rdfs:domain mrc:InstrumentationFeature ;
                             rdfs:range xsd:float ;
                             rdfs:comment "[jSymbolic I-12] Fraction of Note Ons played by acoustic guitar instruments (GM patches 25–26)."@en ;
                             rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                             rdfs:label "Acoustic Guitar Prevalence (I-12)"@en .


###  http://purl.org/ontology/mrc/amountOfArpeggiation
mrc:amountOfArpeggiation rdf:type owl:DatatypeProperty ;
                         rdfs:subPropertyOf mrc:melodicIntervalData ;
                         rdfs:domain mrc:MelodicIntervalFeature ;
                         rdfs:range xsd:float ;
                         rdfs:comment "[jSymbolic M-8] Fraction of melodic intervals that are repeated notes, minor/major thirds, perfect fifths, minor/major sevenths, octaves, minor/major tenths."@en ;
                         rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                         rdfs:label "Amount of Arpeggiation (M-8)"@en .


###  http://purl.org/ontology/mrc/amountOfStaccato
mrc:amountOfStaccato rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf mrc:rhythmData ;
                     rdfs:domain mrc:RhythmFeature ;
                     rdfs:range xsd:float ;
                     rdfs:comment "[jSymbolic RT-15] Number of notes shorter than 0.1 seconds divided by total number of notes."@en ;
                     rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                     rdfs:label "Amount of Staccato (RT-15)"@en .


###  http://purl.org/ontology/mrc/averageIntervalSpannedByMelodicArcs
mrc:averageIntervalSpannedByMelodicArcs rdf:type owl:DatatypeProperty ;
                                        rdfs:subPropertyOf mrc:melodicIntervalData ;
                                        rdfs:domain mrc:MelodicIntervalFeature ;
                                        rdfs:range xsd:float ;
                                        rdfs:comment "[jSymbolic M-24] Average melodic interval in semitones separating the top note of melodic peaks from the bottom note of adjacent troughs."@en ;
                                        rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                                        rdfs:label "Average Interval Spanned by Melodic Arcs (M-24)"@en .


###  http://purl.org/ontology/mrc/averageLengthOfMelodicArcs
mrc:averageLengthOfMelodicArcs rdf:type owl:DatatypeProperty ;
                               rdfs:subPropertyOf mrc:melodicIntervalData ;
                               rdfs:domain mrc:MelodicIntervalFeature ;
                               rdfs:range xsd:float ;
                               rdfs:comment "[jSymbolic M-23] Average number of notes separating melodic peaks and troughs. Set to 0 if no melodic arcs found."@en ;
                               rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                               rdfs:label "Average Length of Melodic Arcs (M-23)"@en .


###  http://purl.org/ontology/mrc/averageNoteDuration
mrc:averageNoteDuration rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf mrc:rhythmData ;
                        rdfs:domain mrc:RhythmFeature ;
                        rdfs:range xsd:float ;
                        rdfs:comment "[jSymbolic RT-13] Average duration of notes in seconds."@en ;
                        rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                        rdfs:label "Average Note Duration (RT-13)"@en .


###  http://purl.org/ontology/mrc/averageNoteToNoteChangeInDynamics
mrc:averageNoteToNoteChangeInDynamics rdf:type owl:DatatypeProperty ;
                                      rdfs:subPropertyOf mrc:dynamicsData ;
                                      rdfs:domain mrc:DynamicsFeature ;
                                      rdfs:range xsd:float ;
                                      rdfs:comment "[jSymbolic D-4] Average change of loudness from one note to the next in the same MIDI channel."@en ;
                                      rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                                      rdfs:label "Average Note to Note Change in Dynamics (D-4)"@en .


###  http://purl.org/ontology/mrc/averageNumberOfIndependentVoices
mrc:averageNumberOfIndependentVoices rdf:type owl:DatatypeProperty ;
                                     rdfs:subPropertyOf mrc:textureData ;
                                     rdfs:domain mrc:TextureFeature ;
                                     rdfs:range xsd:float ;
                                     rdfs:comment "[jSymbolic T-2] Average number of MIDI channels sounding simultaneously, excluding rests."@en ;
                                     rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                                     rdfs:label "Average Number of Independent Voices (T-2)"@en .


###  http://purl.org/ontology/mrc/averageNumberOfSimultaneousPitchClasses
mrc:averageNumberOfSimultaneousPitchClasses rdf:type owl:DatatypeProperty ;
                                            rdfs:subPropertyOf mrc:chordVerticalIntervalData ;
                                            rdfs:domain mrc:ChordVerticalIntervalFeature ;
                                            rdfs:range xsd:float ;
                                            rdfs:comment "[jSymbolic C-4] Average number of different pitch classes sounding simultaneously. Rests excluded."@en ;
                                            rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                                            rdfs:label "Average Number of Simultaneous Pitch Classes (C-4)"@en .


###  http://purl.org/ontology/mrc/averageNumberOfSimultaneousPitches
mrc:averageNumberOfSimultaneousPitches rdf:type owl:DatatypeProperty ;
                                       rdfs:subPropertyOf mrc:chordVerticalIntervalData ;
                                       rdfs:domain mrc:ChordVerticalIntervalFeature ;
                                       rdfs:range xsd:float ;
                                       rdfs:comment "[jSymbolic C-6] Average number of pitches sounding simultaneously (unisons excluded, octaves included)."@en ;
                                       rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                                       rdfs:label "Average Number of Simultaneous Pitches (C-6)"@en .


###  http://purl.org/ontology/mrc/averageRangeOfGlissandos
mrc:averageRangeOfGlissandos rdf:type owl:DatatypeProperty ;
                             rdfs:subPropertyOf mrc:pitchStatisticsData ;
                             rdfs:domain mrc:PitchStatisticsFeature ;
                             rdfs:range xsd:float ;
                             rdfs:comment "[jSymbolic P-39] Average range of MIDI Pitch Bends (max |second_byte - 64|) across all notes with pitch bends. 0 if no pitch bends."@en ;
                             rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                             rdfs:label "Average Range of Glissandos (P-39)"@en .


###  http://purl.org/ontology/mrc/averageRestFractionAcrossVoices
mrc:averageRestFractionAcrossVoices rdf:type owl:DatatypeProperty ;
                                    rdfs:subPropertyOf mrc:rhythmData ;
                                    rdfs:domain mrc:RhythmFeature ;
                                    rdfs:range xsd:float ;
                                    rdfs:comment "[jSymbolic R-43] Average fraction of each MIDI channel's duration during which no note is sounding."@en ;
                                    rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                                    rdfs:label "Average Rest Fraction Across Voices (R-43)"@en .


