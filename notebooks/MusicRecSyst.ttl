                       rdfs:subPropertyOf mrc:rhythmData ;
                       rdfs:domain mrc:RhythmFeature ;
                       rdfs:range xsd:float ;
                       rdfs:comment "[jSymbolic R-45] Longest uninterrupted period with no notes in at least one active MIDI channel, as a fraction of a quarter note."@en ;
                       rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                       rdfs:label "Longest Partial Rest (R-45)"@en .


###  http://purl.org/ontology/mrc/longestRhythmicValue
