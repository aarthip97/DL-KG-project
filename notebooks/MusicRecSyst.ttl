                         rdfs:label "Vertical Minor Seconds (C-15)"@en .


###  http://purl.org/ontology/mrc/verticalMinorThirdPrevalence
mrc:verticalMinorThirdPrevalence rdf:type owl:DatatypeProperty ;
                                 rdfs:subPropertyOf mrc:chordVerticalIntervalData ;
                                 rdfs:domain mrc:ChordVerticalIntervalFeature ;
                                 rdfs:range xsd:float ;
                                 rdfs:comment "[jSymbolic C-25] Fraction of time at least one wrapped vertical minor third is sounding."@en ;
                                 rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                                 rdfs:label "Vertical Minor Third Prevalence (C-25)"@en .


###  http://purl.org/ontology/mrc/verticalOctaves
mrc:verticalOctaves rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf mrc:chordVerticalIntervalData ;
                    rdfs:domain mrc:ChordVerticalIntervalFeature ;
                    rdfs:range xsd:float ;
                    rdfs:comment "[jSymbolic C-22] Fraction of wrapped vertical intervals that are octaves, weighted by duration."@en ;
                    rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                    rdfs:label "Vertical Octaves (C-22)"@en .


###  http://purl.org/ontology/mrc/verticalPerfectFifths
mrc:verticalPerfectFifths rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf mrc:chordVerticalIntervalData ;
                          rdfs:domain mrc:ChordVerticalIntervalFeature ;
                          rdfs:range xsd:float ;
                          rdfs:comment "[jSymbolic C-19] Fraction of wrapped vertical intervals that are perfect fifths, weighted by duration."@en ;
                          rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                          rdfs:label "Vertical Perfect Fifths (C-19)"@en .


###  http://purl.org/ontology/mrc/verticalPerfectFourths
mrc:verticalPerfectFourths rdf:type owl:DatatypeProperty ;
                           rdfs:subPropertyOf mrc:chordVerticalIntervalData ;
                           rdfs:domain mrc:ChordVerticalIntervalFeature ;
                           rdfs:range xsd:float ;
                           rdfs:comment "[jSymbolic C-18] Fraction of wrapped vertical intervals that are perfect fourths, weighted by duration."@en ;
                           rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                           rdfs:label "Vertical Perfect Fourths (C-18)"@en .


###  http://purl.org/ontology/mrc/verticalSevenths
mrc:verticalSevenths rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf mrc:chordVerticalIntervalData ;
                     rdfs:domain mrc:ChordVerticalIntervalFeature ;
                     rdfs:range xsd:float ;
                     rdfs:comment "[jSymbolic C-21] Fraction of wrapped vertical intervals that are minor or major sevenths, weighted by duration."@en ;
                     rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                     rdfs:label "Vertical Sevenths (C-21)"@en .


###  http://purl.org/ontology/mrc/verticalSixths
mrc:verticalSixths rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf mrc:chordVerticalIntervalData ;
                   rdfs:domain mrc:ChordVerticalIntervalFeature ;
                   rdfs:range xsd:float ;
                   rdfs:comment "[jSymbolic C-20] Fraction of wrapped vertical intervals that are minor or major sixths, weighted by duration."@en ;
                   rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                   rdfs:label "Vertical Sixths (C-20)"@en .


###  http://purl.org/ontology/mrc/verticalThirds
mrc:verticalThirds rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf mrc:chordVerticalIntervalData ;
                   rdfs:domain mrc:ChordVerticalIntervalFeature ;
                   rdfs:range xsd:float ;
                   rdfs:comment "[jSymbolic C-16] Fraction of wrapped vertical intervals that are minor or major thirds, weighted by duration."@en ;
                   rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                   rdfs:label "Vertical Thirds (C-16)"@en .


###  http://purl.org/ontology/mrc/verticalTritones
mrc:verticalTritones rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf mrc:chordVerticalIntervalData ;
                     rdfs:domain mrc:ChordVerticalIntervalFeature ;
                     rdfs:range xsd:float ;
                     rdfs:comment "[jSymbolic C-17] Fraction of wrapped vertical intervals that are tritones, weighted by duration."@en ;
                     rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                     rdfs:label "Vertical Tritones (C-17)"@en .


###  http://purl.org/ontology/mrc/verticalUnisons
mrc:verticalUnisons rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf mrc:chordVerticalIntervalData ;
                    rdfs:domain mrc:ChordVerticalIntervalFeature ;
                    rdfs:range xsd:float ;
                    rdfs:comment "[jSymbolic C-14] Fraction of all vertical intervals that are unisons, weighted by duration."@en ;
                    rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                    rdfs:label "Vertical Unisons (C-14)"@en .


###  http://purl.org/ontology/mrc/vibratoPrevalence
mrc:vibratoPrevalence rdf:type owl:DatatypeProperty ;
                      rdfs:subPropertyOf mrc:pitchStatisticsData ;
                      rdfs:domain mrc:PitchStatisticsFeature ;
                      rdfs:range xsd:float ;
                      rdfs:comment "[jSymbolic P-40] Fraction of pitched notes with Pitch Bend messages that change direction ≥2 times."@en ;
                      rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                      rdfs:label "Vibrato Prevalence (P-40)"@en .


###  http://purl.org/ontology/mrc/violinPrevalence
mrc:violinPrevalence rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf mrc:instrumentationData ;
                     rdfs:domain mrc:InstrumentationFeature ;
                     rdfs:range xsd:float ;
                     rdfs:comment "[jSymbolic I-14] Fraction of Note Ons played by violin instruments (GM patches 41 or 111)."@en ;
                     rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                     rdfs:label "Violin Prevalence (I-14)"@en .


###  http://purl.org/ontology/mrc/voiceEqualityDynamics
mrc:voiceEqualityDynamics rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf mrc:textureData ;
                          rdfs:domain mrc:TextureFeature ;
                          rdfs:range xsd:float ;
                          rdfs:comment "[jSymbolic T-6] Standard deviation of average MIDI velocity per channel."@en ;
                          rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                          rdfs:label "Voice Equality – Dynamics (T-6)"@en .


###  http://purl.org/ontology/mrc/voiceEqualityMelodicLeaps
mrc:voiceEqualityMelodicLeaps rdf:type owl:DatatypeProperty ;
                              rdfs:subPropertyOf mrc:textureData ;
                              rdfs:domain mrc:TextureFeature ;
                              rdfs:range xsd:float ;
                              rdfs:comment "[jSymbolic T-7] Standard deviation of average melodic leap distance per channel."@en ;
                              rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                              rdfs:label "Voice Equality – Melodic Leaps (T-7)"@en .


###  http://purl.org/ontology/mrc/voiceEqualityNoteDuration
mrc:voiceEqualityNoteDuration rdf:type owl:DatatypeProperty ;
                              rdfs:subPropertyOf mrc:textureData ;
                              rdfs:domain mrc:TextureFeature ;
                              rdfs:range xsd:float ;
                              rdfs:comment "[jSymbolic T-5] Standard deviation of cumulative sounding time per channel."@en ;
                              rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                              rdfs:label "Voice Equality – Note Duration (T-5)"@en .


###  http://purl.org/ontology/mrc/voiceEqualityNumberOfNotes
mrc:voiceEqualityNumberOfNotes rdf:type owl:DatatypeProperty ;
                               rdfs:subPropertyOf mrc:textureData ;
                               rdfs:domain mrc:TextureFeature ;
                               rdfs:range xsd:float ;
                               rdfs:comment "[jSymbolic T-4] Standard deviation of total Note Ons per channel."@en ;
                               rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                               rdfs:label "Voice Equality – Number of Notes (T-4)"@en .


###  http://purl.org/ontology/mrc/voiceEqualityRange
mrc:voiceEqualityRange rdf:type owl:DatatypeProperty ;
                       rdfs:subPropertyOf mrc:textureData ;
                       rdfs:domain mrc:TextureFeature ;
                       rdfs:range xsd:float ;
                       rdfs:comment "[jSymbolic T-8] Standard deviation of pitch ranges (highest minus lowest pitch) per channel."@en ;
                       rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                       rdfs:label "Voice Equality – Range (T-8)"@en .


###  http://purl.org/ontology/mrc/voiceOverlap
mrc:voiceOverlap rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf mrc:textureData ;
                 rdfs:domain mrc:TextureFeature ;
                 rdfs:range xsd:float ;
                 rdfs:comment "[jSymbolic T-16] Fraction of notes played within the pitch range of another channel."@en ;
                 rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                 rdfs:label "Voice Overlap (T-16)"@en .


###  http://purl.org/ontology/mrc/voiceSeparation
mrc:voiceSeparation rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf mrc:textureData ;
                    rdfs:domain mrc:TextureFeature ;
                    rdfs:range xsd:float ;
                    rdfs:comment "[jSymbolic T-17] Average semitone separation between average pitches of consecutive channels sorted by average pitch."@en ;
                    rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                    rdfs:label "Voice Separation (T-17)"@en .


###  http://purl.org/ontology/mrc/woodwindsPrevalence
mrc:woodwindsPrevalence rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf mrc:instrumentationData ;
                        rdfs:domain mrc:InstrumentationFeature ;
                        rdfs:range xsd:float ;
                        rdfs:comment "[jSymbolic I-17] Fraction of Note Ons played by woodwind instruments (GM patches 69–76)."@en ;
                        rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                        rdfs:label "Woodwinds Prevalence (I-17)"@en .


###  http://purl.org/ontology/mrc/wrappedVerticalIntervalHistogram
mrc:wrappedVerticalIntervalHistogram rdf:type owl:DatatypeProperty ;
                                     rdfs:subPropertyOf mrc:chordVerticalIntervalData ;
                                     rdfs:domain mrc:ChordVerticalIntervalFeature ;
                                     rdfs:range xsd:string ;
                                     rdfs:comment "[jSymbolic C-2] 12-bin histogram of vertical intervals folded by octave (0–11 semitones). Stored as space-separated floats."@en ;
                                     rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                                     rdfs:label "Wrapped Vertical Interval Histogram (C-2)"@en .


#################################################################
#    Classes
#################################################################

###  http://purl.org/NET/c4dm/event.owl#Event
event:Event rdf:type owl:Class .


###  http://purl.org/ontology/mo/Genre
mo:Genre rdf:type owl:Class ;
         owl:sameAs wd:Q188451 ;
         mo:level "2" ;
         rdfs:comment """
        An expressive style of music.
        
        Any taxonomy can be plug-in here. You can either define a genre by yourself, like this:

        :mygenre a mo:Genre; dc:title \"electro rock\".

        Or you can refer to a DBPedia genre (such as http://dbpedia.org/resource/Baroque_music), allowing semantic web
        clients to access easily really detailed structured information about the genre you are refering to.

        Aligned to wd:Q188451 (Wikidata: music genre) via owl:sameAs.
    """ ;
         rdfs:isDefinedBy mo: ;
         rdfs:label "Genre" ;
         vs:term_status "stable" .


###  http://purl.org/ontology/mo/Instrument
mo:Instrument rdf:type owl:Class ;
              mo:level "2" ;
              rdfs:comment """
        Any of various devices or contrivances that can be used to produce musical tones or sound.
        
        Any taxonomy can be used to subsume this concept. The default one is one extracted by Ivan Herman
        from the Musicbrainz instrument taxonomy, conforming to SKOS. This concept holds a seeAlso link 
        towards this taxonomy.
    """ ;
              rdfs:isDefinedBy mo: ;
              rdfs:label "Instrument" ;
              rdfs:seeAlso <http://purl.org/ontology/mo/mit#> ;
              vs:term_status "stable" .


###  http://purl.org/ontology/mo/MusicArtist
mo:MusicArtist rdf:type owl:Class ;
               rdfs:subClassOf foaf:Agent ;
               mo:level "1" ;
               rdfs:comment """
        A person or a group of people (or a computer :-) ), whose musical 
        creative work shows sensitivity and imagination 
    """ ;
               rdfs:isDefinedBy mo: ;
               rdfs:label "music artist" ;
               vs:term_status "stable" .


###  http://purl.org/ontology/mo/Performance
mo:Performance rdf:type owl:Class ;
               rdfs:subClassOf event:Event ;
               mo:level "2" ;
               rdfs:comment """
        A performance event. 
        It might include as agents performers, engineers, conductors, or even listeners.
        It might include as factors a score, a MusicalWork, musical instruments. 
        It might produce a sound:-)
    """ ;
               rdfs:isDefinedBy mo: ;
               rdfs:label "performance" ;
               vs:term_status "stable" .


###  http://purl.org/ontology/mo/Performer
mo:Performer rdf:type owl:Class ;
             owl:equivalentClass [ rdf:type owl:Restriction ;
                                   owl:onProperty mo:performed ;
                                   owl:someValuesFrom mo:Performance
                                 ] ;
             rdfs:subClassOf foaf:Agent ;
             mo:level "2" ;
             rdfs:label "performer" ;
             vs:term_status "unstable" .


###  http://purl.org/ontology/mrc/ChordVerticalIntervalFeature
mrc:ChordVerticalIntervalFeature rdf:type owl:Class ;
                                 rdfs:subClassOf mrc:MusicFeature ;
                                 rdfs:comment """jSymbolic category: Chords and Vertical Intervals.
Covers the types of vertical intervals and chords present, harmonic
movement rate, and the prevalence of specific interval types."""@en ;
                                 rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                                 rdfs:label "Chord and Vertical Interval Feature"@en .


###  http://www.wikidata.org/entity/Q39911
###  Reused as rdfs:range of mrc:releaseDecade — not redefined, only annotated locally.
wd:Q39911 rdf:type owl:Class ;
          rdfs:subClassOf wd:Q186081 ;
          rdfs:label "decade"@en ;
          rdfs:comment """Wikidata class for a 10-year time period (wd:Q39911). Reused directly as
the range of mrc:releaseDecade. As a subclass of wd:Q186081 (time interval),
decades are part of (wdt:P361) a century (wd:Q578), which is itself a
rdfs:subClassOf wd:Q186081. Instances are Wikidata Q-items such as:
  wd:Q34653  (1990s), wd:Q34052  (1980s), wd:Q2002   (2000s), wd:Q19609  (2010s).
Each instance has the following Wikidata properties:
  - wdt:P31  (instance of)  → wd:Q39911 (decade)
  - wdt:P361 (part of)      → wd:Q6927  (20th century) or wd:Q6939 (21st century),
                               both instances of wd:Q578 (century)
  - wdt:P155 (follows)      → the preceding decade individual
  - wdt:P156 (followed by)  → the succeeding decade individual"""@en .


###  http://www.wikidata.org/prop/direct/P31
wdt:P31 rdf:type owl:ObjectProperty ;
        rdfs:label "instance of"@en ;
        rdfs:comment "Wikidata property P31: the class(es) of which this item is an instance. Used on decade individuals: wdt:P31 wd:Q39911."@en .


###  http://www.wikidata.org/prop/direct/P361
wdt:P361 rdf:type owl:ObjectProperty ;
         rdfs:label "part of"@en ;
         rdfs:comment "Wikidata property P361: the larger whole of which this item is a part. Used on decade individuals to link to the parent century (wd:Q6927 or wd:Q6939)."@en .


###  http://www.wikidata.org/prop/direct/P155
wdt:P155 rdf:type owl:ObjectProperty ;
         rdfs:label "follows"@en ;
         rdfs:comment "Wikidata property P155: the item that immediately precedes this one in a series. Used on decade individuals to link to the previous decade."@en .


###  http://www.wikidata.org/prop/direct/P156
wdt:P156 rdf:type owl:ObjectProperty ;
         rdfs:label "followed by"@en ;
         rdfs:comment "Wikidata property P156: the item that immediately follows this one in a series. Used on decade individuals to link to the next decade."@en .


###  http://www.wikidata.org/entity/Q186081
###  Reused as the common superclass of time-structured units (decade, century).
wd:Q186081 rdf:type owl:Class ;
           rdfs:label "time interval"@en ;
           rdfs:comment """Wikidata class for a time interval (wd:Q186081): a continuous segment of
time bounded by a start and end point. Used here as the common superclass
of wd:Q578 (century) and wd:Q39911 (decade):
  wd:Q578   rdfs:subClassOf wd:Q186081  (century is a time interval)
  wd:Q39911 rdfs:subClassOf wd:Q186081  (decade is a time interval)"""@en .


###  http://www.wikidata.org/entity/Q578
###  Reused as the class of century individuals referenced via wdt:P361 from decade instances.
wd:Q578 rdf:type owl:Class ;
        rdfs:subClassOf wd:Q186081 ;
        rdfs:label "century"@en ;
        rdfs:comment """Wikidata class for a 100-year time period (wd:Q578). A century is a
rdfs:subClassOf wd:Q186081 (time interval). Decade instances (wd:Q39911)
link to century instances via wdt:P361 (part of). Examples used in this
ontology:
  wd:Q6927  (20th century) — parent of decades wd:Q34052 (1980s), wd:Q34653 (1990s)
  wd:Q6939  (21st century) — parent of decades wd:Q2002  (2000s), wd:Q19609 (2010s)"""@en .


###  http://www.wikidata.org/entity/Q188451
###  Reused as the Wikidata counterpart of mrc:Genre and mo:Genre via owl:sameAs.
wd:Q188451 rdf:type owl:Class ;
           rdfs:label "music genre"@en ;
           rdfs:comment """Wikidata class for a music genre (wd:Q188451). Aligned to this ontology via:
  mrc:Genre owl:sameAs wd:Q188451
  mo:Genre  owl:sameAs wd:Q188451
Genre classes in this ontology are subclasses of mo:Genre (and transitively
of wd:Q188451). Specific Wikidata genre classes can be declared as
rdfs:subClassOf wd:Q188451, e.g.:
  wd:Q37073  (pop music)  rdfs:subClassOf wd:Q188451
  wd:Q11399  (rock music) rdfs:subClassOf wd:Q188451
A genre such as pop rock can be a rdfs:subClassOf both:
  wd:Q37073 (pop music) and wd:Q11399 (rock music) — multiple inheritance.
Example instance: wd:Q484641 (pop rock) wdt:P31 wd:Q188451 (instance of music genre)."""@en .


###  http://www.wikidata.org/entity/Q37073
###  Wikidata class for pop music — used as a superclass of pop-derived genre subclasses.
wd:Q37073 rdf:type owl:Class ;
          rdfs:subClassOf wd:Q188451 ;
          rdfs:label "pop music"@en ;
          rdfs:comment """Wikidata class for pop music (wd:Q37073), itself an instance/subclass of
music genre (wd:Q188451). Genre classes that are subgenres of pop can declare:
  <genre> rdfs:subClassOf wd:Q37073 .
Example: pop rock (wd:Q484641) rdfs:subClassOf wd:Q37073 (and also wd:Q11399)."""@en .


###  http://www.wikidata.org/entity/Q11399
###  Wikidata class for rock music — used as a superclass of rock-derived genre subclasses.
wd:Q11399 rdf:type owl:Class ;
          rdfs:subClassOf wd:Q188451 ;
          rdfs:label "rock music"@en ;
          rdfs:comment """Wikidata class for rock music (wd:Q11399), itself an instance/subclass of
music genre (wd:Q188451). Genre classes that are subgenres of rock can declare:
  <genre> rdfs:subClassOf wd:Q11399 .
Example: pop rock (wd:Q484641) rdfs:subClassOf wd:Q11399 (and also wd:Q37073),
demonstrating multiple inheritance — pop rock sits at the intersection of
pop music and rock music."""@en .


###  http://purl.org/ontology/mrc/DynamicsFeature
mrc:DynamicsFeature rdf:type owl:Class ;
                    rdfs:subClassOf mrc:MusicFeature ;
                    rdfs:comment """jSymbolic category: Dynamics.
Covers the loudness of notes (MIDI velocity), dynamic range, variation
in dynamics, and the prevalence of loud vs. soft notes."""@en ;
                    rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                    rdfs:label "Dynamics Feature"@en .


###  http://purl.org/ontology/mrc/Genre
mrc:Genre rdf:type owl:Class ;
          rdfs:subClassOf mo:Genre ;
          owl:sameAs wd:Q188451 ;
          rdfs:comment """A music genre associated with an artist (not a track directly, as MSD
provides genre at the artist level). Aligned to wd:Q188451 (Wikidata: music genre)
via owl:sameAs. Specific genre subclasses may additionally align to Wikidata
genre Q-items, e.g.:
  mrc:PopRock rdfs:subClassOf wd:Q37073 (pop music)
              rdfs:subClassOf wd:Q11399  (rock music)
Both wd:Q37073 and wd:Q11399 are themselves rdfs:subClassOf wd:Q188451."""@en ;
          rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
          rdfs:label "MRC Genre"@en .


###  http://purl.org/ontology/mrc/InstrumentationFeature
mrc:InstrumentationFeature rdf:type owl:Class ;
                           rdfs:subClassOf mrc:MusicFeature ;
                           rdfs:comment """jSymbolic category: Instrumentation.
Covers which MIDI instruments (pitched and unpitched) are present, their
relative emphasis, and the number and variety of instruments used."""@en ;
                           rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                           rdfs:label "Instrumentation Feature"@en .


###  http://purl.org/ontology/mrc/Listener
mrc:Listener rdf:type owl:Class ;
             owl:equivalentClass [ rdf:type owl:Restriction ;
                                   owl:onProperty mo:listened ;
                                   owl:someValuesFrom mo:Performance
                                 ] ;
             rdfs:subClassOf foaf:Agent ;
             rdfs:label "listener" .


###  http://purl.org/ontology/mrc/MSDMusicArtist
mrc:MSDMusicArtist rdf:type owl:Class ;
                   rdfs:subClassOf mo:Performer ;
                   rdfs:subClassOf mo:MusicArtist ;
                   rdfs:comment """A music artist/performer whose metadata originates from the Million Song Dataset,
enriched with MusicBrainz identifiers. Genre information is associated at
the artist level (not the track level) since that is what MSD provides."""@en ;
                   rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                   rdfs:label "MSD Music Artist"@en .


###  http://purl.org/ontology/mrc/MSDTrack
mrc:MSDTrack rdf:type owl:Class ;
             rdfs:subClassOf mrc:Track ;
             rdfs:comment """A track from the Million Song Dataset (MSD). Extends mrc:Track with
MSD-specific identifiers, audio-derived metadata, and links to jSymbolic
feature extractions from the associated MIDI file."""@en ;
             rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
             rdfs:label "MSD Track"@en .


###  http://purl.org/ontology/mrc/MelodicIntervalFeature
mrc:MelodicIntervalFeature rdf:type owl:Class ;
                           rdfs:subClassOf mrc:MusicFeature ;
                           rdfs:comment """jSymbolic category: Melodies and Horizontal Intervals.
Covers the melodic interval histogram and derived statistics: most common
interval, mean interval, arpeggiation, melodic contour, direction of
motion, and phrase-level features. Features M-1 onwards."""@en ;
                           rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                           rdfs:label "Melodic Interval Feature"@en .


###  http://purl.org/ontology/mrc/MusicFeature
mrc:MusicFeature rdf:type owl:Class ;
                 rdfs:comment """An abstract class representing a bundle of features extracted from a
musical piece (typically from a MIDI file using jSymbolic). Subclasses
correspond to the seven jSymbolic feature categories."""@en ;
                 rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                 rdfs:label "Music Feature"@en .


###  http://purl.org/ontology/mrc/PitchStatisticsFeature
mrc:PitchStatisticsFeature rdf:type owl:Class ;
                           rdfs:subClassOf mrc:MusicFeature ;
                           rdfs:comment """jSymbolic category: Pitch Statistics.
Covers overall statistics on pitches present in a piece without regard to
temporal order: pitch histograms, range, tonal centres, mean/variance/
skewness/kurtosis of pitch and pitch class distributions, glissando and
vibrato prevalence. Features P-1 to P-41."""@en ;
                           rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                           rdfs:label "Pitch Statistics Feature"@en .


###  http://purl.org/ontology/mrc/RhythmFeature
mrc:RhythmFeature rdf:type owl:Class ;
                  rdfs:subClassOf mrc:MusicFeature ;
                  rdfs:comment """jSymbolic category: Rhythm.
Covers time intervals between note attacks, note durations, meter,
rhythmic patterns, use of rubato, and rhythmic variation between voices.
Includes time signature features."""@en ;
                  rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                  rdfs:label "Rhythm Feature"@en .


###  http://purl.org/ontology/mrc/TextureFeature
mrc:TextureFeature rdf:type owl:Class ;
                   rdfs:subClassOf mrc:MusicFeature ;
                   rdfs:comment """jSymbolic category: Texture.
Covers the number of independent voices, polyphonic vs. homophonic
texture, voice overlap, and the relative importance of voices."""@en ;
                   rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                   rdfs:label "Texture Feature"@en .


###  http://purl.org/ontology/mrc/Track
mrc:Track rdf:type owl:Class ;
          rdfs:comment """An MRC-defined track class representing a concrete audio or MIDI track
as encountered in music datasets (e.g. the Million Song Dataset). This class
is intentionally distinct from mo:Track (which models a MusicalItem in the
FRBR manifestation-item sense) to better suit dataset-oriented use cases.
Subclassed by mrc:MSDTrack for MSD-specific instances."""@en ;
          rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
          rdfs:label "MRC Track"@en .


