                                        rdfs:domain mrc:PitchStatisticsFeature ;
                                        rdfs:range xsd:integer ;
                                        rdfs:comment "[jSymbolic P-22] Absolute semitone difference between the two most frequently occurring pitches."@en ;
                                        rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                                        rdfs:label "Interval Between Most Prevalent Pitches (P-22)"@en .


###  http://purl.org/ontology/mrc/listenCount
mrc:listenCount rdf:type owl:DatatypeProperty ;
                rdfs:domain mrc:Listener ;
                rdfs:range xsd:integer ;
                rdfs:comment """Records the number of times a given listener (foaf:Person / mrc:Listener)
has listened to a specific mrc:Track. This property is used directly on the
Listener-to-Track edge in the simplified property-graph view of the KG,
replacing MO's reification-based mo:listened → mo:Performance model.
Only tracks with a count of 5 or more are included (listenCount >= 5)."""@en ;
                rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                rdfs:label "Listen Count"@en .


###  http://purl.org/ontology/mrc/lastPitch
mrc:lastPitch rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf mrc:pitchStatisticsData ;
              rdfs:domain mrc:PitchStatisticsFeature ;
              rdfs:range xsd:integer ;
              rdfs:comment "[jSymbolic P-36] MIDI pitch of the last note. If simultaneous attacks, lowest pitch is chosen. 0 if no pitched notes."@en ;
              rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
              rdfs:label "Last Pitch (P-36)"@en .


###  http://purl.org/ontology/mrc/lastPitchClass
mrc:lastPitchClass rdf:type owl:DatatypeProperty ;
                   rdfs:subPropertyOf mrc:pitchStatisticsData ;
                   rdfs:domain mrc:PitchStatisticsFeature ;
                   rdfs:range xsd:integer ;
                   rdfs:comment "[jSymbolic P-37] Pitch class (0–11) of the last note. 0 = C."@en ;
                   rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                   rdfs:label "Last Pitch Class (P-37)"@en .


###  http://purl.org/ontology/mrc/longestCompleteRest
mrc:longestCompleteRest rdf:type owl:DatatypeProperty ;
                        rdfs:subPropertyOf mrc:rhythmData ;
                        rdfs:domain mrc:RhythmFeature ;
                        rdfs:range xsd:float ;
                        rdfs:comment "[jSymbolic R-44] Longest uninterrupted period with no pitched notes, as a fraction of a quarter note."@en ;
                        rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                        rdfs:label "Longest Complete Rest (R-44)"@en .


###  http://purl.org/ontology/mrc/longestPartialRest
