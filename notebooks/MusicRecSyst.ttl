###  http://purl.org/ontology/mrc/melodicFifths
mrc:melodicFifths rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf mrc:melodicIntervalData ;
                  rdfs:domain mrc:MelodicIntervalFeature ;
                  rdfs:range xsd:float ;
                  rdfs:comment "[jSymbolic M-15] Fraction of melodic intervals that are perfect fifths."@en ;
                  rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                  rdfs:label "Melodic Fifths (M-15)"@en .


###  http://purl.org/ontology/mrc/melodicIntervalData
mrc:melodicIntervalData rdf:type owl:DatatypeProperty ;
                        rdfs:domain mrc:MelodicIntervalFeature ;
                        rdfs:range rdfs:Literal ;
                        rdfs:comment "Parent data property for all jSymbolic Melodic Interval (M-*) feature values. All M-* data properties are rdfs:subPropertyOf this property."@en ;
                        rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                        rdfs:label "Melodic Interval Feature Data"@en .


###  http://purl.org/ontology/mrc/melodicIntervalHistogram
mrc:melodicIntervalHistogram rdf:type owl:DatatypeProperty ;
                             rdfs:subPropertyOf mrc:melodicIntervalData ;
                             rdfs:domain mrc:MelodicIntervalFeature ;
                             rdfs:range xsd:string ;
                             rdfs:comment "[jSymbolic M-1] 128-bin normalized histogram. Bin index = semitones in the melodic interval (rising and falling treated identically). Stored as a space-separated list of 128 float values."@en ;
                             rdfs:isDefinedBy <http://purl.org/ontology/mrc/> ;
                             rdfs:label "Melodic Interval Histogram (M-1)"@en .


