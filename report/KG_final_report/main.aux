\@writefile{lof}{\contentsline {figure}{\numberline {21}{\ignorespaces HGT attention rationale — success case: \textit  {Toxic} by Britney Spears recommended to user\#161346 (HIT $\text  {$\mathsurround \z@ \mathchar "458$}$, score $+0.459$). Attention concentrates on tracks sharing the \textit  {pop/dance pop} genre and \textit  {Allegro} tempo class.}}{19}{figure.21}\protected@file@percent }
\newlabel{fig:hgt_exp_success}{{21}{19}{HGT attention rationale — success case: \textit {Toxic} by Britney Spears recommended to user\#161346 (HIT $\checkmark $, score $+0.459$). Attention concentrates on tracks sharing the \textit {pop/dance pop} genre and \textit {Allegro} tempo class}{figure.21}{}}
