\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces Population-level summary comparing all models (including HGT in self-evaluation mode) across genre diversity, decade coverage, and popularity of recommendations. The HGT produces the most musically diverse recommendations of all evaluated models, consistent with its low Popularity Bias.}}{16}{figure.18}\protected@file@percent }
\newlabel{fig:pop_summary_app}{{18}{16}{Population-level summary comparing all models (including HGT in self-evaluation mode) across genre diversity, decade coverage, and popularity of recommendations. The HGT produces the most musically diverse recommendations of all evaluated models, consistent with its low Popularity Bias}{figure.18}{}}
