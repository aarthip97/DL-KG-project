\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces Key metrics at $K\in \{5,10,20,50,100\}$ for all models. KNN-CF's Overall Score advantage grows with $K$ as its catalogue-coverage advantage compounds. MostPopular leads on Recall and NDCG at every $K$ but achieves near-zero coverage throughout.}}{15}{figure.16}\protected@file@percent }
\newlabel{fig:multik_app}{{16}{15}{Key metrics at $K\in \{5,10,20,50,100\}$ for all models. KNN-CF's Overall Score advantage grows with $K$ as its catalogue-coverage advantage compounds. MostPopular leads on Recall and NDCG at every $K$ but achieves near-zero coverage throughout}{figure.16}{}}
