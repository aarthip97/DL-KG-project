\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces Top-20 XGBoost features by cumulative gain. AE embedding dimensions dominate, with the user-profile AE dimensions contributing more than track-side dimensions, indicating that user preference representation is the primary driver of re-ranking decisions.}}{17}{figure.19}\protected@file@percent }
\newlabel{fig:xgb_importance}{{19}{17}{Top-20 XGBoost features by cumulative gain. AE embedding dimensions dominate, with the user-profile AE dimensions contributing more than track-side dimensions, indicating that user preference representation is the primary driver of re-ranking decisions}{figure.19}{}}
\newlabel{fig:xgb_importance@cref}{{[figure][19][]19}{[1][17][]17}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {20}{\ignorespaces SHAP beeswarm summary over 1,000 sampled test users. Each point is one (user, track) pair; colour encodes feature value. AE embedding dimensions concentrate the largest SHAP magnitudes, confirming that the autoencoder bottleneck is the primary information carrier for re-ranking. Categorical features (genre, key, tempo class) contribute more modestly.}}{18}{figure.20}\protected@file@percent }
\newlabel{fig:shap_summary}{{20}{19}{SHAP beeswarm summary over 1,000 sampled test users. Each point is one (user, track) pair; colour encodes feature value. AE embedding dimensions concentrate the largest SHAP magnitudes, confirming that the autoencoder bottleneck is the primary information carrier for re-ranking. Categorical features (genre, key, tempo class) contribute more modestly}{figure.20}{}}
