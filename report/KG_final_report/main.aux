\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces HGT training curves (200 epochs, RotatE init). \textit  {Left}: listwise debiased loss decreases monotonically. \textit  {Centre}: validation Recall@10. \textit  {Right}: validation NDCG@10. All three panels confirm stable optimisation with no divergence.}}{14}{figure.15}\protected@file@percent }
\newlabel{fig:hgt_curves_app}{{15}{15}{HGT training curves (200 epochs, RotatE init). \textit {Left}: listwise debiased loss decreases monotonically. \textit {Centre}: validation Recall@10. \textit {Right}: validation NDCG@10. All three panels confirm stable optimisation with no divergence}{figure.15}{}}
\newlabel{fig:hgt_curves_app@cref}{{[figure][15][]15}{[1][15][]15}{}{}{}}
